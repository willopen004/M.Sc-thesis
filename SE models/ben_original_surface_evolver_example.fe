//set the force acting on a protein
procedure setforce(integer pro_id, real forcex, real forcey, real forcez) {
	checkproid(pro_id);
	if pro_id = 1 then { FORCE1_X := forcex; FORCE1_Y := forcey; FORCE1_Z := forcez; };
	if pro_id = 2 then { FORCE2_X := forcex; FORCE2_Y := forcey; FORCE2_Z := forcez; };
	if pro_id = 3 then { FORCE3_X := forcex; FORCE3_Y := forcey; FORCE3_Z := forcez; };
