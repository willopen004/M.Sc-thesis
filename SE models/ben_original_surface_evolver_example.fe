//read the force acting on a protein		 
function real readforce(integer pro_id, integer dimension) {
	checkproid(pro_id);
	if dimension > 3 or dimension < 1 then {
		printf "dimension = %d must be 1, 2 or 3\n",dimension;
		endjob();
	};
	if pro_id=1 then { if dimension=1 then {return FORCE1_X;}; if dimension=2 then {return FORCE1_Y;}; if dimension=3 then {return FORCE1_Z;};};
	if pro_id=2 then { if dimension=1 then {return FORCE2_X;}; if dimension=2 then {return FORCE2_Y;}; if dimension=3 then {return FORCE2_Z;};};
