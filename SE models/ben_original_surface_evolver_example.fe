	if pro_id=10 then { if dimension=1 then {return FORCE10_X;}; if dimension=2 then {return FORCE10_Y;}; if dimension=3 then {return FORCE10_Z;};};
	if pro_id=11 then { if dimension=1 then {return FORCE11_X;}; if dimension=2 then {return FORCE11_Y;}; if dimension=3 then {return FORCE11_Z;};};
	if pro_id=12 then { if dimension=1 then {return FORCE12_X;}; if dimension=2 then {return FORCE12_Y;}; if dimension=3 then {return FORCE12_Z;};};
