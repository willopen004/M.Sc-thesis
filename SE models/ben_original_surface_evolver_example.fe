procedure res() {
	load datafilename;
};

PARAMETER STARTING_TILT := PI/4    // radians; tilt about +y from +x toward +z

//SET PARAMETERS

//to do with the geometry

PARAMETER	R_PRO			= 1		// radius of protein in membrane
PARAMETER	R_RIM			= 1000		// radius for rim of membrane
PARAMETER	Z_RIM			= 0.0		// initial guess for height of rim
PARAMETER	ALPHA			= asin(0.375)		// angle of interception with membrane corresponds to 0.15 curvature

CONSTRAINT_TOLERANCE: 1e-7

PARAMETER	PRO1_X			=  2		// initial position of protein
PARAMETER	PRO1_Y			=  0
PARAMETER	PRO1_Z			=  0

PARAMETER	OR1_X			=  0		// initial orientation of protein - do not change!
PARAMETER	OR1_Y			=  0
PARAMETER	OR1_Z			=  1

PARAMETER 	BOX_ANGLE		= PI		// what is the angle of the simulation box
							// (i.e. for a multibody calculate with 3 proteins it would be 2*PI/3;

PARAMETER	STARTING_DISTANCE	= 20.0	// distance of protein at initial force measurment
PARAMETER 	MOVE_SHIFT		= 0.1		// distance that the protein is shifted after each scan

PARAMETER	NUM_PROS		= 1		// number of proteins

//membrane tension

PARAMETER  	MEMBRANE_TENSION	= 0.0		// tension of the membrane

//to do with the calculation of energy gradients

PARAMETER  	TILT_STEP		= 1e-11		// size of tilt step used to determine the gradient
PARAMETER  	DIST_STEP		= 1e-11 	// size of distance step used to determine the gradient

//variables to pass to command files if needed

PARAMETER      GENERIC1	       	        = 0
PARAMETER      GENERIC2			= 0
PARAMETER      GENERIC3			= 0
PARAMETER      GENERIC4			= 0

//to do with moving of proteins (if used at all)

PARAMETER 	TRANSLATE_FRICTION	= 5		// (size of force)/(size of step)
PARAMETER 	TILT_FRICTION		= 20

PARAMETER 	TRANSLATE_MAX		= 1		// maximum size of the step
PARAMETER 	TILT_MAX		= 1

//used by functions

PARAMETER FIRST_PROTEIN_CONSTRAINT	= 5

//numerical

PARAMETER  	CONVERGE_TOLERANCE 	= 1e-08	// tolerance for energy discrepancies as a fraction of the total energy

//to do with the coarsening of the triangulation

//coarsening of the triangulation is controlled by setting maximum and minimum allowable edge lengths
//these maximum and minimum depend on distance from the centre of the simulation box and on the color of the faces
//basing it on distance makes the initial setting up a bit smoother
//basing it on color allows us to tune the refinement based on the curvature

PARAMETER	RADIUS_SMALL		= 4*R_PRO	// distance from protein beyond which triangulation starts to coarsen
//within distance RADIUS_SMALL the minimum edge length is given by the variable length_small
//length_small depends on the level by length_small = LENGTH_SMALL_L1 * 2 / 2^(level) 
PARAMETER 	LENGTH_SMALL_L1		= 1;
//the maximum edge length is simply the minimum edge length multplied by the factor RFACTOR
PARAMETER  	RFACTOR		 	= 3
//the minimum dihedral_angle is a factor of RFACTOR smaller than DIHEDRAL_MAX
PARAMETER	DFACTOR			= 3
//beyond a distance of RADIUS_SMALL from the protein the minimum edge length depends on this distance and is calculate by
//minimum edge length = length_small * (distance/RADIUS_SMALL)^LENGTH_SCALING
PARAMETER  	LENGTH_SCALING		= 1.0

PARAMETER  	DIHEDRAL_MAX		= 0.02	//maximum dihedral angle	
PARAMETER  	DIHEDRAL_TOLERANCE_FACTOR	= 2	//dihedral angle can actually be this times as large as dihedral_max
PARAMETER 	COLORSCALE		= 1.5		//length of edges changes by this factor in one color step
PARAMETER	COLOR_DOWN_CHANCE	= 0.2		//probability that a face that has too high a color gets stepped down

PARAMETER SPHERE_RADIUS 		= R_PRO/SIN(ALPHA)		//radius of sphere that describes protein
PARAMETER  DIST_TO_CENTRE 		= SPHERE_RADIUS * COS(ALPHA)	//distance from centre of protein to centre of sphere

PARAMETER LENGTH_SMALL 			= LENGTH_SMALL_L1		//initialise length_small

PARAMETER TILT_SAFETY_FACTOR		= 10	//how max tilt depends on proximity of another constraint
PARAMETER TRANSLATE_SAFETY_FACTOR	= 10	//how max translation depends on proximity of another constraint


PARAMETER MAX_NUM_PROS			= 25	//routines work for up to this many proteins

quantity sqmean energy modulus 0 method star_perp_sq_mean_curvature global

define vertex attribute con integer
define edge attribute lengoal real

//DEFINE THE FUNCTION

procedure endjob() {
	load "die";   //this file does not exist so program exits (I know it's messy!)	
}

// checks if a given protein id is sensible
procedure checkproid(integer pro_id) {
	if pro_id > NUM_PROS or pro_id < 1 then {
		printf "pro_id = %d is larger than NUM_PROS = %d or less than 1\n",pro_id, NUM_PROS;
		endjob();
	};
	if NUM_PROS > MAX_NUM_PROS then {
		printf "NUM_PROS = %d is larger than MAX_NUM_PROS = %d\n",NUM_PROS, MAX_NUM_PROS;
		endjob();
	};
}	

// sets the position of a protein based on the given id
procedure setpos(integer pro_id, real posx, real posy, real posz) {
	checkproid(pro_id);
	if pro_id = 1 then { PRO1_X := posx; PRO1_Y := posy; PRO1_Z := posz; };
	if pro_id = 2 then { PRO2_X := posx; PRO2_Y := posy; PRO2_Z := posz; };
	if pro_id = 3 then { PRO3_X := posx; PRO3_Y := posy; PRO3_Z := posz; };
	if pro_id = 4 then { PRO4_X := posx; PRO4_Y := posy; PRO4_Z := posz; };
	if pro_id = 5 then { PRO5_X := posx; PRO5_Y := posy; PRO5_Z := posz; };
	if pro_id = 6 then { PRO6_X := posx; PRO6_Y := posy; PRO6_Z := posz; };
	if pro_id = 7 then { PRO7_X := posx; PRO7_Y := posy; PRO7_Z := posz; };
	if pro_id = 8 then { PRO8_X := posx; PRO8_Y := posy; PRO8_Z := posz; };
	if pro_id = 9 then { PRO9_X := posx; PRO9_Y := posy; PRO9_Z := posz; };
	if pro_id = 10 then { PRO10_X := posx; PRO10_Y := posy; PRO10_Z := posz; };
	if pro_id = 11 then { PRO11_X := posx; PRO11_Y := posy; PRO11_Z := posz; };
	if pro_id = 12 then { PRO12_X := posx; PRO12_Y := posy; PRO12_Z := posz; };
	if pro_id = 13 then { PRO13_X := posx; PRO13_Y := posy; PRO13_Z := posz; };
	if pro_id = 14 then { PRO14_X := posx; PRO14_Y := posy; PRO14_Z := posz; };
	if pro_id = 15 then { PRO15_X := posx; PRO15_Y := posy; PRO15_Z := posz; };
	if pro_id = 16 then { PRO16_X := posx; PRO16_Y := posy; PRO16_Z := posz; };
	if pro_id = 17 then { PRO17_X := posx; PRO17_Y := posy; PRO17_Z := posz; };
	if pro_id = 18 then { PRO18_X := posx; PRO18_Y := posy; PRO18_Z := posz; };
	if pro_id = 19 then { PRO19_X := posx; PRO19_Y := posy; PRO19_Z := posz; };
	if pro_id = 20 then { PRO20_X := posx; PRO20_Y := posy; PRO20_Z := posz; };
	if pro_id = 21 then { PRO21_X := posx; PRO21_Y := posy; PRO21_Z := posz; };
	if pro_id = 22 then { PRO22_X := posx; PRO22_Y := posy; PRO22_Z := posz; };
	if pro_id = 23 then { PRO23_X := posx; PRO23_Y := posy; PRO23_Z := posz; };
	if pro_id = 24 then { PRO24_X := posx; PRO24_Y := posy; PRO24_Z := posz; };
	if pro_id = 25 then { PRO25_X := posx; PRO25_Y := posy; PRO25_Z := posz; };
}

//reads a coordinate of a protein position
function real readpos(integer pro_id, integer dimension) {
	checkproid(pro_id);
	if dimension > 3 or dimension < 1 then {
		printf "dimension = %d must be 1, 2 or 3\n",dimension;
		endjob();
	};
	if pro_id=1 then { if dimension=1 then { return PRO1_X; }; if dimension=2 then { return PRO1_Y; }; if dimension=3 then { return PRO1_Z; };};
	if pro_id=2 then { if dimension=1 then { return PRO2_X; }; if dimension=2 then { return PRO2_Y; }; if dimension=3 then { return PRO2_Z; };};
