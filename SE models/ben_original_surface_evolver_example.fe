//returns the magnitude of the force acting on a protein
function real forcemag(integer pro_id) {
	return (readforce(pro_id,1)^2 + readforce(pro_id,2)^2 + readforce(pro_id,3)^2)^0.5;
}

//returns the magnitude of the torque acting on a protein
function real torquemag(integer pro_id) {
	return (readtorque(pro_id,1)^2 + readtorque(pro_id,2)^2 + readtorque(pro_id,3)^2)^0.5;
}

//calculates the elements of a rotation matrix based on axis and angle.  elements are global variables.
procedure setrotationmatrix(real angle, real axisx, real axisy, real axisz) {
	local axislength; axislength := (axisx^2 + axisy^2 + axisz^2)^0.5;
	axisx := axisx/axislength;
	axisy := axisy/axislength;
	axisz := axisz/axislength;
	cosangle := cos(angle);
	sinangle := sin(angle);

	Rxx := (1-cosangle)*axisx*axisx + cosangle;
	Rxy := (1-cosangle)*axisx*axisy - sinangle*axisz;
	Rxz := (1-cosangle)*axisx*axisz + sinangle*axisy;
	Ryx := (1-cosangle)*axisy*axisx + sinangle*axisz;
	Ryy := (1-cosangle)*axisy*axisy + cosangle;
	Ryz := (1-cosangle)*axisy*axisz - sinangle*axisx;
	Rzx := (1-cosangle)*axisz*axisx - sinangle*axisy;
	Rzy := (1-cosangle)*axisz*axisy + sinangle*axisx;
	Rzz := (1-cosangle)*axisz*axisz + cos(angle);
}

//retrns whether a given constraint corresponds to a protein constraint
function integer v_on_protein(integer vcon) {
	if vcon >= FIRST_PROTEIN_CONSTRAINT then {
		return 1;
	} else {
		return 0;
	};
}

//returns whether a given constraint in an box edge constraint
function integer v_on_edge(integer vcon) {
	if vcon > 0 and vcon < FIRST_PROTEIN_CONSTRAINT then {
		return 1;
	} else {
		return 0;
	};
}

//returns whether a given constraint corresponds to the boundary of a protein
function integer v_on_protein_edge(integer vcon) {
	if vcon >= FIRST_PROTEIN_CONSTRAINT and 2*floor(vcon/2) = vcon then {
		return 1;
	} else {
		return 0;
	};
}

//returns whether a given edge id corresponds to a box edge
function integer e_on_edge(integer e_id) {
	if edges[e_id].__e_constraint_list[1] > 1 then {
		if edges[e_id].__e_constraint_list[2] < FIRST_PROTEIN_CONSTRAINT then {
			return 1;
		};
	};
	return 0;
}

//returns whether a given edge id corresponds to an edge in the middle of a protein (i.e. not on its boundary)
function integer e_in_protein_middle(integer e_id) {
	if edges[e_id].__e_constraint_list[1] = 1 then {
		if edges[e_id].__e_constraint_list[2] >= FIRST_PROTEIN_CONSTRAINT then {
			return 1;
		};
	};
	return 0;
}	

//calculates the centre of the sphere which describes a protein
function real centre(integer pro_id, integer dimension) {
	checkproid(pro_id);
	if dimension > 3 or dimension < 1 then {
		printf "dimension = %d must be 1, 2 or 3\n",dimension;
		endjob();
	};
	return readpos(pro_id,dimension) + reador(pro_id,dimension)*DIST_TO_CENTRE;
}

//returns the area of a triangel where a and b are two edges
function real triangle_area (real ax, real ay, real az, real bx, real by, real bz) {
	local areacalc;
	areacalc := (ay*bz-az*by)^2 + (ax*bz-az*bx)^2 + (ax*by-ay*bx)^2;
	areacalc := sqrt(areacalc)/2;
	return areacalc; 
}

//unfixes all the vertices -- required before doing refinement, coarsening or retriangulation
procedure unfixall() {
	unfix vertices where con >= 0;
}

//fixes vertices on protein constraints -- required before minimising energy -- assumes constraints are turned off
procedure fixall() {
	fix vertices where con >= FIRST_PROTEIN_CONSTRAINT;
}

//turns protein constraints off -- required before minimising or calculating energy
procedure conoff() {
	set vertex con 0;
	local ii; local cc;
	for (cc := 1; cc < FIRST_PROTEIN_CONSTRAINT; cc+=1) {
		set vertex con cc where on_constraint cc;
	};
	for (ii := 1; ii <= NUM_PROS; ii += 1) {
		set vertex con FIRST_PROTEIN_CONSTRAINT-2+2*ii where on_constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii;
		set vertex con FIRST_PROTEIN_CONSTRAINT-1+2*ii where on_constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii;
		unset vertex constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii;
		unset vertex constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii;
	};
}

//turns protein constraints on -- required before doing refinement, coarsening or retriangulation
procedure conon() {
	local ii;
	for (ii := 1; ii <= NUM_PROS; ii += 1) {
		set vertex constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii where con=FIRST_PROTEIN_CONSTRAINT-2+2*ii or con=FIRST_PROTEIN_CONSTRAINT-1+2*ii;
		set vertex constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii where con=FIRST_PROTEIN_CONSTRAINT-1+2*ii;
	};
}

//works out what length each edge should be
procedure setlengoals() {
	local distance;
	local colorlevel;
	local fi;
	local xpos; local ypos;
	local x_at_protein;
	foreach edge ee do {
		xpos := ee.vertex[1].x/2 + ee.vertex[2].x/2;
		ypos := ee.vertex[1].y/2 + ee.vertex[2].y/2;
		distance :=  (xpos^2+ypos^2)^0.5;
		if distance < RADIUS_SMALL then {
			ee.lengoal := length_small;
		} else {
			ee.lengoal := (distance/RADIUS_SMALL)^LENGTH_SCALING*length_small;
		};
		colorlevel := 0;
		for (fi :=1;fi<=ee.valence;fi+=1) {
			colorlevel += ee.facets[fi].color;
		};
		colorlevel := colorlevel/ee.valence;
		ee.lengoal := ee.lengoal/COLORSCALE^(colorlevel);
	};
}

//deletes all edges smaller than they should be
procedure coarsen() {
	unfixall();
	conon();
	delete edge ee where length < ee.lengoal;
	conoff();
	fixall();
}

//refine all edges longer than they should be
procedure rnew() {
	unfixall();
	conon();
	setlengoals();
	refine edge ee where length > RFACTOR * ee.lengoal; 
	conoff();
	fixall();
}

//does equiangulation
procedure unew() {
	unfixall();
	conon();
	u;
	conoff();
	fixall();
}

//checks to see if any dihedral_angles are larger than they should be
//if they are the color of the appropriate faces is increased to reduce the edge lengths
procedure dihedral_color(real dihedral_cutoff) {
	local temp;
	local random1;
	local colorav;
	local ei; local fi;local ii;local vi;
	local countercol;

	foreach facet ff do {

		// if a dihedral angle is too large increase the color of surrounding faces
		if (ff.edges[1].dihedral > dihedral_cutoff or ff.edges[2].dihedral > dihedral_cutoff or ff.edges[3].dihedral > dihedral_cutoff) then {
			temp :=  ff.color;
			ff.color := temp + 1;
		};

		// if a dihedral angle is too small decease the color of surrounding faces
		// do not apply to faces on the edge of the box since dihedrals not calculated here
		if  (ff.edges[1].dihedral < dihedral_cutoff/DFACTOR  and ff.edges[2].dihedral < dihedral_cutoff/DFACTOR  and ff.edges[3].dihedral < dihedral_cutoff/DFACTOR
		and (e_on_edge(ff.edges[1].id) = 0) and (e_on_edge(ff.edges[2].id) = 0) and (e_on_edge(ff.edges[3].id) = 0)) then {
			if ff.color > 0 then {
				temp := ff.color;
				random1 := random;
				if random < COLOR_DOWN_CHANCE then {
					ff.color := temp - 1;
				};
			};
		};
	};

	//now set each facets color to average of its own and surrounding facets colors
	//this helps stability		
	foreach facet ff do {
		colorav := 0;
		countercol := 0;
		for (ei := 1; ei <= ff.valence; ei += 1) {
			for (fi := 1; fi <= ff.edges[ei].valence; fi += 1) {
				colorav += ff.edges[ei].facets[fi].color;
				countercol += 1;
			};
		};
		colorav := colorav/countercol;
		random1 := random;
		if random < (ceil(colorav) - colorav) then {
			colorav := floor(colorav);
		} else {
			colorav := ceil(colorav);
		};
		ff.color := colorav;
	};		
		
}

//refines, coarsens, etc surface
procedure rf() {rnew();unew();coarsen();unew();}

//sets the level of refinement
//useful for initial setting up
procedure setlevel (integer level_set) {
	level := level_set;
	length_small := LENGTH_SMALL_L1*2/(2^level);
}

//translate a protein and the surrounds membrane with it
function real translateproteinsmooth (integer pro_id, real stepx, real stepy, real stepz) {
	local steplength;
	steplength := (stepx^2+stepy^2+stepz^2)^0.5;
	local con_num; local con_edge_num;
	local centrex; local centrey; local centrez;
	centrex := readpos(pro_id,1);
	centrey := readpos(pro_id,2);
	centrez := readpos(pro_id,3);
	con_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-2;
	con_edge_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-1;
	local distance;
	local stepscale;

	//find closest protein edge or wall
	local lebensraum;
	lebensraum := R_RIM;
	foreach vertex vv where (v_on_edge(vv.con) = 1 or v_on_protein_edge(vv.con) = 1) and vv.con != con_edge_num do {
		distance := ( (vv.x-centrex)^2 + (vv.y-centrey)^2 + (vv.z-centrez)^2 )^0.5;
		distance_par_or := (vv.x-centrex)*reador(pro_id,1)+(vv.y-centrey)*reador(pro_id,2)+(vv.z-centrez)*reador(pro_id,3);
		distance_perp_or := sqrt(distance^2-distance_par_or^2);
		distance := sqrt(distance_par_or^2 + (maximum(distance_perp_or,R_PRO)-R_PRO)^2);
		lebensraum := minimum(lebensraum,distance);
	};
	if lebensraum < TRANSLATE_SAFETY_FACTOR*steplength then {
		movefactor := lebensraum/(TRANSLATE_SAFETY_FACTOR*steplength);
	} else {
		movefactor := 1;
	};

	foreach vertex vv do {
		distance := ((vv.x-centrex)^2+(vv.y-centrey)^2+(vv.z-centrez)^2)^0.5;
		distance_par_or := (vv.x-centrex)*reador(pro_id,1)+(vv.y-centrey)*reador(pro_id,2)+(vv.z-centrez)*reador(pro_id,3);
		distance_perp_or := sqrt(distance^2-distance_par_or^2);
		distance := sqrt(distance_par_or^2 + (maximum(distance_perp_or,R_PRO)-R_PRO)^2);

		if distance < lebensraum then {
			stepscale := (cos(pi*distance/lebensraum) + 1)/2;
			vv.x := vv.x + stepscale*stepx*movefactor; 
			vv.y := vv.y + stepscale*stepy*movefactor; 
			vv.z := vv.z + stepscale*stepz*movefactor; 
		};
	};
	setpos(pro_id,centrex + stepx*movefactor,centrey + stepy*movefactor,centrez + stepz*movefactor);
	printf "protein %d - translation direction %f %f %f - dist tried %f - dist moved %f - lebensraum %f\n",
		pro_id, stepx/steplength, stepy/steplength, stepz/steplength,steplength, steplength*movefactor, lebensraum;
	return movefactor*steplength;
}

//tilt a protein and the surrounds membrane with it
function real tiltproteinsmooth (integer pro_id, real angle, real axisx, real axisy, real axisz) {
	local axis_length;
	axis_length := (axisx^2+axisy^2+axisz^2)^0.5;
	axisx := axisx/axis_length;
	axisy := axisy/axis_length;
	axisz := axisz/axis_length;

	local con_num; local con_edge_num;
	local centrex; local centrey; local centrez;
	centrex := readpos(pro_id,1);
	centrey := readpos(pro_id,2);
	centrez := readpos(pro_id,3);
	con_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-2;
	con_edge_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-1;
	local distance; local distance_par_or; local distance_perp_or;
	local anglescale;

	//find closest protein edge or wall
	local lebensraum;
	lebensraum := R_RIM;
	foreach vertex vv where (v_on_edge(vv.con) = 1 or v_on_protein_edge(vv.con) = 1) and vv.con != con_edge_num do {
		distance := ((vv.x-centrex)^2+(vv.y-centrey)^2+(vv.z-centrez)^2)^0.5;
		distance_par_or := (vv.x-centrex)*reador(pro_id,1)+(vv.y-centrey)*reador(pro_id,2)+(vv.z-centrez)*reador(pro_id,3);
		distance_perp_or := sqrt(distance^2-distance_par_or^2);
		distance := sqrt(distance_par_or^2 + (maximum(distance_perp_or,R_PRO)-R_PRO)^2);
		lebensraum := minimum(lebensraum,distance);
	};
	if lebensraum < abs(TILT_SAFETY_FACTOR*angle*R_PRO) then {
		movefactor := lebensraum/abs((TILT_SAFETY_FACTOR*angle*R_PRO));
	} else {
		movefactor := 1;
	};
	local counter; counter := 1;
	foreach vertex vv do {
		if vv.con = con_num or vv.con = con_edge_num then {
			anglescale := 1;
		} else {
			distance := ((vv.x-centrex)^2+(vv.y-centrey)^2+(vv.z-centrez)^2)^0.5;
			distance_par_or := (vv.x-centrex)*reador(pro_id,1)+(vv.y-centrey)*reador(pro_id,2)+(vv.z-centrez)*reador(pro_id,3);
			distance_perp_or := sqrt(distance^2-distance_par_or^2);
			distance := sqrt(distance_par_or^2 + (maximum(distance_perp_or,R_PRO)-R_PRO)^2);
			if distance < lebensraum then {
				anglescale := (cos(pi*distance/lebensraum) + 1)/2.0;
			};
			if distance >= lebensraum then {		
				anglescale := 0;
			};
		};
		//get rotation matrix
		counter += 1;
		setrotationmatrix(angle*anglescale*movefactor,axisx,axisy,axisz);
		local xnew; local ynew; local znew;
		xnew := centrex + Rxx * (vv.x-centrex) + Rxy * (vv.y-centrey) + Rxz * (vv.z-centrez);
		ynew := centrey + Ryx * (vv.x-centrex) + Ryy * (vv.y-centrey) + Ryz * (vv.z-centrez);
		znew := centrez + Rzx * (vv.x-centrex) + Rzy * (vv.y-centrey) + Rzz * (vv.z-centrez);
		vv.x := xnew;
		vv.y := ynew;
		vv.z := znew;
	};

	//get new orientation vector
	setrotationmatrix(angle*movefactor,axisx,axisy,axisz);
	local orx; local ory; local orz;
	orx := reador(pro_id,1);
	ory := reador(pro_id,2);
	orz := reador(pro_id,3);
	setor(pro_id,Rxx * orx + Rxy * ory + Rxz * orz,Ryx * orx + Ryy * ory + Ryz * orz,Rzx * orx + Rzy * ory + Rzz * orz);
	printf "protein %d - tilt direction %f %f %f - angle tried %f - angle rotated %f - lebensraum %f\n",pro_id, axisx, axisy, axisz,angle, angle*movefactor, lebensraum;
	return angle*movefactor;
}

//translate a protein - but not any membrane
procedure translateprotein (integer pro_id,real stepx, real stepy, real stepz) {
	local steplength;
	steplength := (stepx^2+stepy^2+stepz^2)^0.5;
	local con_num; local con_edge_num;
	local centrex; local centrey; local centrez;
	centrex := readpos(pro_id,1);
	centrey := readpos(pro_id,2);
	centrez := readpos(pro_id,3);
	con_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-2;
	con_edge_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-1;
	movefactor := 1;
	foreach vertex vv where con=con_num or con=con_edge_num  do {
		vv.x := vv.x + stepx*movefactor;
		vv.y := vv.y + stepy*movefactor;
		vv.z := vv.z + stepz*movefactor;
	};
	setpos(pro_id,centrex + stepx*movefactor,centrey + stepy*movefactor,centrez + stepz*movefactor);
}

//tilt a protein - but not any membrane
procedure tiltprotein (integer pro_id, real angle, real axisx, real axisy, real axisz) {
	local axis_length;
	axis_length := (axisx^2+axisy^2+axisz^2)^0.5;
	axisx := axisx/axis_length;
	axisy := axisy/axis_length;
	axisz := axisz/axis_length;

	local con_num; local con_edge_num;
	local centrex; local centrey; local centrez;
	centrex := readpos(pro_id,1);
	centrey := readpos(pro_id,2);
	centrez := readpos(pro_id,3);
	con_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-2;
	con_edge_num := pro_id * 2 + FIRST_PROTEIN_CONSTRAINT-1;

	//get rotation matrix
	setrotationmatrix(angle,axisx,axisy,axisz);
	foreach vertex vv where con=con_num or con=con_edge_num do {
		local xnew; local ynew; local znew;
		xnew := centrex + Rxx * (vv.x-centrex) + Rxy * (vv.y-centrey) + Rxz * (vv.z-centrez);
		ynew := centrey + Ryx * (vv.x-centrex) + Ryy * (vv.y-centrey) + Ryz * (vv.z-centrez);
		znew := centrez + Rzx * (vv.x-centrex) + Rzy * (vv.y-centrey) + Rzz * (vv.z-centrez);
		vv.x := xnew;
		vv.y := ynew;
		vv.z := znew;
	};

	//get new orientation vector
	local orx; local ory; local orz;
	orx := reador(pro_id,1);
	ory := reador(pro_id,2);
	orz := reador(pro_id,3);
	setor(pro_id,Rxx * orx + Rxy * ory + Rxz * orz,Ryx * orx + Ryy * ory + Ryz * orz,Rzx * orx + Rzy * ory + Rzz * orz);
}

//calculate the force acting on a protein - assumes we have converged membrane shape
procedure calcforce (integer pro_id, real step) {
	local nrg; nrg := total_energy;
	local dEdd_x; local dEdd_y; local dEdd_z;
	translateprotein(pro_id,step,0,0);
	dEdd_x := (total_energy - nrg)/step;
	translateprotein(pro_id,-step,step,0);
	dEdd_y := (total_energy - nrg)/step;
	translateprotein(pro_id,0,-step,step);
	dEdd_z := (total_energy - nrg)/step;
	translateprotein(pro_id,0,0,-step);
	setforce(pro_id,-dEdd_x,-dEdd_y,-dEdd_z);
}

procedure printforce (integer pro_id) {
	printf "%1.12f %1.12f %1.12f\n",readforce(pro_id,1),readforce(pro_id,2),readforce(pro_id,3);
}
procedure printtorque (integer pro_id) {
	printf "%1.12f %1.12f %1.12f\n",readtorque(pro_id,1),readtorque(pro_id,2),readtorque(pro_id,3);
}

//calculate the torque acting on a protein -- assumes we have converged membrane shape
procedure calctorque (integer pro_id, real angle) {
	local nrg; nrg := total_energy;
	local dEdt_x; local dEdt_y; local dEdt_z;
	tiltprotein(pro_id,angle,1,0,0);
	dEdt_x := (total_energy - nrg)/angle;
	tiltprotein(pro_id,angle,-1,0,0);
	tiltprotein(pro_id,angle,0,1,0);
	dEdt_y := (total_energy - nrg)/angle;
	tiltprotein(pro_id,angle,0,-1,0);
	tiltprotein(pro_id,angle,0,0,1);
	dEdt_z := (total_energy - nrg)/angle;
	tiltprotein(pro_id,angle,0,0,-1);
	settorque(pro_id,-dEdt_x, -dEdt_y, -dEdt_z);
}

//converges the shape of the membrane 
procedure converge(integer hessian_calls, integer refine_every_step) {
	local energy_old; energy_old := total_energy;
	local energy_vold; energy_vold := total_energy;
	local energy_vvold; energy_vvold := total_energy;
	local energy_diff; energy_diff := 999999999;
	local repeat_counts; repeat_counts := 0;
	local trickystuff; if hessian_calls = 0 then { trickystuff := 1; hessian_calls := 1 } else { trickystuff := 0 };
	while energy_diff > CONVERGE_TOLERANCE*maximum(maximum(energy_old,energy_vold),energy_vvold) do {
		if refine_every_step = 1 or (repeat_counts = 0 and !(trickystuff = 1 and hessian_calls > 1)) then { 
			rnew();unew();coarsen();unew();
		};
		{hessian_seek} hessian_calls;
		energy_diff := minimum(minimum(abs(total_energy - energy_old),abs(total_energy-energy_vold)),abs(total_energy-energy_vvold));
		energy_vvold := energy_vold;
		energy_vold := energy_old;
		energy_old := total_energy;
		repeat_counts += 1;
		if trickystuff = 1 and repeat_counts = 4 then {
			repeat_counts := 0;
			hessian_calls += 1;
		};
	};
}

procedure fastconverge() {
	local energy_old; energy_old := total_energy; 
	local energy_vold; energy_vold := total_energy;	       
	local energy_vvold; energy_vvold := total_energy;
	local energy_diff; energy_diff := 999999999;
	loop_size := 2;
	counter := 0;
	while energy_diff > CONVERGE_TOLERANCE*maximum(maximum(energy_old,energy_vold),energy_vvold) do {
	        rnew();unew();coarsen();unew();
	        for (loop := 1; loop <= loop_size; loop += 1) {
		        hessian_seek;
			if loop = loop_size - 1 then {
			        energy_2ndtolast := total_energy;
			};
		};
		if loop_size > 1 and (abs(total_energy - energy_2ndtolast) < CONVERGE_TOLERANCE) then {
		   	loop_size -= 1;
			counter := 0;
		} else {
		        counter += 1;
		};
		if counter = 4 then {
		   	loop_size += 1;
			counter := 0;
		};
		energy_diff := minimum(minimum(abs(total_energy - energy_old),abs(total_energy-energy_vold)),abs(total_energy-energy_vvold));
		energy_vvold := energy_vold;
		energy_vold := energy_old;
		energy_old := total_energy;
	};
};

//adjusts the color of faces until there remain no edges with large dihedral angles
procedure colorconverge(integer hessian_calls) {
	local sharpangles;
	sharpangles := 1;
	while sharpangles != 0 do {
		fastconverge();
		dihedral_color(DIHEDRAL_MAX);
		sharpangles := 0;
		foreach edge ee where e_in_protein_middle(ee.id) = 0 and  dihedral > DIHEDRAL_MAX * DIHEDRAL_TOLERANCE_FACTOR do sharpangles += 1;
		printf "There are %d sharp edges left in the simulation\n",sharpangles;
	};
}

//runs converge and colorconverge
procedure convergesimple() {
	colorconverge(0);
	fastconverge();
};

//proteins move according to the forces and torques on them
procedure moveproteins(integer moveprotein1) {
	//find forces and torques on proteins
	local ii;
	for (ii := 1; ii <= NUM_PROS; ii += 1) {
		calcforce(ii,DIST_STEP);
		calctorque(ii,TILT_STEP);
	};

	local step;
	local tilt;
	local force;
	local torque;
	local dist_moved; local angle_moved;
	local start_protein; start_protein := 1;
	if (moveprotein1 = 0) then {
		start_protein := 2;
		force := readforce(1,3);
		step := force/TRANSLATE_FRICTION;
		if step > TRANSLATE_MAX then step := TRANSLATE_MAX;
		dist_moved := translateproteinsmooth(1,0,0,step);
		printf "%f %f %f %f %f %f %f %f %f %f %f %f ",
			readpos(1,1), readpos(1,2), readpos(1,3), reador(1,1), reador(1,2), reador(1,3), 
			readforce(1,1), readforce(1,2), readforce(1,3), readtorque(1,1), readtorque(1,2), readtorque(1,3)
		>> "n2a5-8n002d2-0e8.move";
	};
	for (ii := start_protein; ii <= NUM_PROS; ii += 1) {
		force := forcemag(ii);
		torque := torquemag(ii);
		step := force/TRANSLATE_FRICTION;
		tilt := torque/TILT_FRICTION;
		if step > TRANSLATE_MAX then step := TRANSLATE_MAX; 
		if tilt > TILT_MAX then tilt := TILT_MAX; 
		dist_moved := translateproteinsmooth(ii,step*readforce(ii,1)/force,step*readforce(ii,2)/force,step*readforce(ii,3)/force);
		anglemoved := tiltproteinsmooth(ii,tilt,readtorque(ii,1)/torque,readtorque(ii,2)/torque,readtorque(ii,3)/torque);
		printf "%f %f %f %f %f %f %f %f %f %f %f %f ",
			readpos(ii,1), readpos(ii,2), readpos(ii,3), reador(ii,1), reador(ii,2), reador(ii,3), 
			readforce(ii,1), readforce(ii,2), readforce(ii,3), readtorque(ii,1), readtorque(ii,2), readtorque(ii,3)
		>> "n2a5-8n002d2-0e8.move";
	};
	printf "\n" >> "n2a5-8n002d2-0e8.move";
}

procedure measure_and_print(integer pro_id) {
	calctorque(pro_id,tilt_step);
	calcforce(pro_id,dist_step);
	printf "Position is %f %f %f Orientation is %f %f %f Force is %f %f %f Torque is %f %f %f ",
		readpos(pro_id,1),readpos(pro_id,2),readpos(pro_id,3),
		reador(pro_id,1),reador(pro_id,2),reador(pro_id,3),
		readforce(pro_id,1),readforce(pro_id,2),readforce(pro_id,3),
		readtorque(pro_id,1),readtorque(pro_id,2),readtorque(pro_id,3);
	calctorque(pro_id,tilt_step*10);
	calcforce(pro_id,dist_step*10);
	printf "Force_check is %f %f %f Torque_check is %f %f %f Energy is %f\n",
		readforce(pro_id,1),readforce(pro_id,2),readforce(pro_id,3),
		readtorque(pro_id,1),readtorque(pro_id,2),readtorque(pro_id,3), total_energy;
};	


//find the tilt of a protein that sets torque to 0
//an axis around which the protein is tilted must be given so that search is in 1D not 3D!
procedure optimisetilt (integer pro_id, real axis_x, real axis_y, real axis_z, real step, real min_step, real torque_tolerance) {
	local torquex; local torquey; local torquez;
	local axislength;
	local angle_tilted;
	axislength := (axis_x^2 + axis_y^2 + axis_z^2)^0.5;
	axis_x := axis_x/axislength;
	axis_y := axis_y/axislength;
	axis_z := axis_z/axislength;
	local magnitude;
	convergesimple();
	calctorque(pro_id,tilt_step);
	magnitude1 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;

	measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.optimisetilt";
	
	local direction_tilt;
	if magnitude1 > 0 then {direction_tilt := 1} else {direction_tilt := -1};
	
	angle_tilted := tiltproteinsmooth(pro_id,direction_tilt*step,axis_x,axis_y,axis_z);
	convergesimple();
	calctorque(pro_id,tilt_step);
	magnitude2 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
	measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.optimisetilt";

	while magnitude1 * magnitude2 > 0 do {
		angle_tilted := tiltproteinsmooth(pro_id,angle_tilted*2,axis_x,axis_y,axis_z);
		convergesimple();
		calctorque(pro_id,tilt_step);
		magnitude1 := magnitude2;
		magnitude2 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
		measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.optimisetilt";
	};

	printf "angle_tilted is %f and min_step is %f and magnitude is %f and torque_tolerance is %f\n",angle_tilted,min_step,magnitude2,torque_tolerance;
	while (abs(angle_tilted) > min_step and abs(magnitude2) > torque_tolerance) do {
		angle_tilted := tiltproteinsmooth(pro_id,-angle_tilted/2,axis_x,axis_y,axis_z);
		convergesimple();
		calctorque(pro_id,tilt_step);
		magnitude1 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
		if magnitude1 * magnitude2 > 0 then {
			angle_tilted := -angle_tilted;
		};
		magnitude2 := magnitude1;
		measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.optimisetilt";

	};
}

//scan back and forth around the point where the torque goes to 0
procedure zoomscan_tilts(integer pro_id, real axis_x, real axis_y, real axis_z, real step, real num_steps, real num_scans) {
	local torquex; local torquey; local torquez;
	local axislength;
	local angle_tilted;
	axislength := (axis_x^2 + axis_y^2 + axis_z^2)^0.5;
	axis_x := axis_x/axislength;
	axis_y := axis_y/axislength;
	axis_z := axis_z/axislength;
	local magnitude;
	convergesimple();
	calctorque(pro_id,tilt_step);
	magnitude1 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
	measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";
	
	local direction_tilt;
	if magnitude1 > 0 then {direction_tilt := 1} else {direction_tilt := -1};
	total_angle_tilted := 0;
	angle_tilted := tiltproteinsmooth(pro_id,direction_tilt*step,axis_x,axis_y,axis_z);
	total_angle_tilted += angle_tilted;
	convergesimple();
	calctorque(pro_id,tilt_step);
	magnitude2 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
	measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";

	if direction_tilt*magnitude1 < -direction_tilt*magnitude2/2 then {
		while direction_tilt*magnitude1 < -direction_tilt*magnitude2/2 do {
			angle_tilted := tiltproteinsmooth(pro_id,-total_angle_tilted/2,axis_x,axis_y,axis_z);
			total_angle_tilted += angle_tilted;
			convergesimple();
			calctorque(pro_id,tilt_step);
			magnitude2 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
			measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";
		};
	} else {

		while direction_tilt*magnitude1 > -direction_tilt*magnitude2 do {
			angle_tilted := tiltproteinsmooth(pro_id,angle_tilted*2,axis_x,axis_y,axis_z);
			total_angle_tilted += angle_tilted;
			convergesimple();
			calctorque(pro_id,tilt_step);
			magnitude2 := readtorque(pro_id,1) * axis_x +  readtorque(pro_id,2) * axis_y + readtorque(pro_id,3) * axis_z;
			measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";
		};
	};
	angle_change := total_angle_tilted;
	total_angle := total_angle_tilted;
	angle_step := angle_change/num_steps;
	for (ii := 0; ii < num_scans; ii += 1) {
		while (abs(total_angle) > 0) do {
			angle_tilted := tiltproteinsmooth(pro_id,-direction_tilt*minimum(abs(angle_step), abs(total_angle)),axis_x,axis_y,axis_z);
			convergesimple();
			measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";
			total_angle += angle_tilted;
		};
		while (abs(total_angle) < abs(angle_change)) do {
			angle_tilted := tiltproteinsmooth(pro_id,direction_tilt*minimum(abs(angle_step), abs(angle_change)-abs(total_angle)),axis_x,axis_y,axis_z);
			convergesimple();
			measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.zoomscan";
			total_angle += angle_tilted;
		};
	};
}

procedure scan_tilts(integer pro_id, real axis_x, real axis_y, real axis_z, real angle_change, real angle_step, real min_angle) {
	local torquex; local torquey; local torquez;
	local axislength;
	local total_angle; total_angle := 0;
	local angle_tilted; angle_tilted := angle_change;
	local direction; direction := angle_change/abs(angle_change);
	axislength := (axis_x^2 + axis_y^2 + axis_z^2)^0.5;
	axis_x := axis_x/axislength;
	axis_y := axis_y/axislength;
	axis_z := axis_z/axislength;
	convergesimple();
	measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.scan";
	while (abs(total_angle) < abs(angle_change)) and (abs(angle_tilted) > abs(min_angle)) do {
		angle_tilted := tiltproteinsmooth(pro_id,direction*minimum(abs(angle_step), abs(angle_change)-abs(total_angle)),axis_x,axis_y,axis_z);
		convergesimple();
		measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.scan";
		total_angle += angle_tilted;
	};
	while (abs(total_angle) > 0) do {
		angle_tilted := tiltproteinsmooth(pro_id,-direction*minimum(abs(angle_step), abs(total_angle)),axis_x,axis_y,axis_z);
		convergesimple();
		measure_and_print(pro_id) >> "n2a5-8n002d2-0e8.scan";
		total_angle += angle_tilted;
	};
	convergesimple();
}
	
		

procedure initialise() {
	foreach face ff do ff.color := 0;
	set facet tension MEMBRANE_TENSION;
	sqmean.modulus := 1;

	conoff();
	fixall();

	setlevel(1);
}

//DEFINE THE CONSTRAINTS

constraint 1              /* reflection */
//formula: x1/cos(box_angle/2) = x2/sin(box_angle/2)
formula: x1 = 0

constraint 2              /* reflection */
//formula: x1/cos(box_angle/2) = -x2/sin(box_angle/2)
formula: x1 = 0

constraint 3              /* the boundary rim */
formula: x1^2 + x2^2 = R_RIM^2

constraint 5              /* protein 1 */
formula: (x1 - PRO1_X - OR1_X * DIST_TO_CENTRE)^2 + (x2-PRO1_Y - OR1_Y * DIST_TO_CENTRE)^2 + (x3-PRO1_Z - OR1_Z * DIST_TO_CENTRE)^2 = SPHERE_RADIUS^2

constraint 6              /* protein 1 edge*/
formula: (x1 - PRO1_X + OR1_X * DIST_TO_CENTRE)^2 + (x2-PRO1_Y + OR1_Y * DIST_TO_CENTRE)^2 + (x3-PRO1_Z + OR1_Z * DIST_TO_CENTRE)^2 = SPHERE_RADIUS^2


//DEFINE THE STARTING GEOMETRY

vertices   // given in terms of boundary parameter

//boundary rim
1    0     			0      				0		constraint 1 constraint 2
2    cos(box_angle/2)*R_RIM	sin(box_angle/2)*R_RIM  	Z_RIM  		constraint 3 constraint 1 
3    R_RIM  			0    				Z_RIM  		constraint 3 
4    cos(box_angle/2)*R_RIM     -sin(box_angle/2)*R_RIM		Z_RIM  		constraint 3 constraint 2 

//protein 1 edge
5	PRO1_X-R_PRO	PRO1_Y		PRO1_Z		constraint 5	constraint 6
6	PRO1_X		PRO1_Y+R_PRO	PRO1_Z		constraint 5	constraint 6
7	PRO1_X+R_PRO	PRO1_Y		PRO1_Z		constraint 5	constraint 6
8	PRO1_X		PRO1_Y-R_PRO	PRO1_Z		constraint 5	constraint 6		
 
//protein 1 centre
9	PRO1_X		PRO1_Y		PRO1_Z+DIST_TO_CENTRE-SPHERE_RADIUS	constraint 5

edges

//edges on boundary rim
1	1	2	constraint 1
2	2	3	constraint 3
3	3	4	constraint 3
4	4	1	constraint 2

//edges between proteins and boundary rim
5	1	5
6	2	6
7	3	7
8	4	8

//edges within protein 1
9	5	6	constraint 5	constraint 6
10	6	7	constraint 5	constraint 6
11	7	8	constraint 5	constraint 6
12	8	5	constraint 5	constraint 6
13	5	9	constraint 5
14	6	9	constraint 5
15	7	9	constraint 5
16	8	9	constraint 5

faces
//faces between proteins and rim
1	1	6	-9	-5
2	2	7	-10	-6
3	3	8	-11	-7
4	4	5	-12	-8
	
//within protein 1
5	9	14	-13	 constraint 5
6	10	15	-14	 constraint 5
7	11	16	-15	 constraint 5
8	12	13	-16	 constraint 5

//9 9 10 11 12 color red
read

showq;
//  now the starting commands


procedure runme() {
  run_tilt := 0;   // set to 1 to apply the single tilt

  true_DIHEDRAL_MAX := DIHEDRAL_MAX;
  DIHEDRAL_MAX := 0.2;
  true_CONVERGE_TOLERANCE := CONVERGE_TOLERANCE;
  CONVERGE_TOLERANCE := CONVERGE_TOLERANCE*1000;

  initialise();

  setlevel(1);
  {rf()} 8;
  set facet tension 0.1;
  converge(5,1);
  set facet tension MEMBRANE_TENSION;
  converge(5,1);
  setlevel(2);
  {rf()} 3;
  converge(0,1);
  setlevel(3);
  {rf()} 3;
  convergesimple();

/*
// ALIGN OR1 TO +X (always)
while abs(OR1_Z) > 0.0001 do {
  local theta;
  if OR1_X = 0 then theta := PI/2 else theta := atan(OR1_Z/-OR1_X);
  angle_tilted := tiltproteinsmooth(1,-theta,0,1,0);
  convergesimple();
};
// Optional demo tilt only when run_tilt=1
if (run_tilt) then {
  angle_tilted := tiltproteinsmooth(1, STARTING_TILT, 0, 1, 0);
  convergesimple();
};
*/
  // lock the starting distance (this runs regardless of run_tilt)
  desired_distance := STARTING_DISTANCE;
  while abs(PRO1_X - desired_distance) > 0.0000001 do {
    distance_translated := translateproteinsmooth(1,-PRO1_X+desired_distance,0,0);
    convergesimple();
  };

  CONVERGE_TOLERANCE := true_CONVERGE_TOLERANCE;
  convergesimple();
  DIHEDRAL_MAX := true_DIHEDRAL_MAX;
  convergesimple();
  
    // === ENERGY COMPARISON AT FIXED DISTANCE =========================
  // Baseline: NO TILT (OR1 is aligned to +x; do not tilt)
  convergesimple();
  E_no_tilt := total_energy;

  // Zero-torque tilt about +y (find equilibrium tilt at SAME distance)
  // step, min_step, torque_tolerance tuned for robustness
  optimisetilt(1, 0, 1, 0, PI/36, PI/2000, 1e-10);
  convergesimple();
  E_tilt := total_energy;

/* true tilt about +y from +z toward +x */
tilt_rad := atan2(OR1_X, OR1_Z);        /* gives φ in [-PI, PI] */
tilt_deg := tilt_rad * 180.0 / PI;      /* degrees */

/* (optional) wrap to [0,360):
# if tilt_deg < 0 then tilt_deg := tilt_deg + 360;
*/

printf "=== ZERO-TORQUE === r_over_a=%f  E_no_tilt=%.12g  E_tilt=%.12g  dE=%.12g  tilt(rad)=%f  tilt(deg)=%f\n",
   2*PRO1_X/R_PRO, E_no_tilt, E_tilt, (E_tilt - E_no_tilt), tilt_rad, tilt_deg;

/* also log to file */
printf "%f %f %f %f %f %f %.12g %.12g %.12g %f %f\n",
   readpos(1,1), readpos(1,2), readpos(1,3),
   reador(1,1), reador(1,2), reador(1,3),
   E_no_tilt, E_tilt, (E_tilt - E_no_tilt),
   tilt_rad, tilt_deg
   >> "tilt_compare.txt";
  // ================================================================


  //if (run_tilt) then {
  //  scan_tilts(1, 0, 1, 0, PI/2, PI/2/40, PI/2/1000);
  //};
}







