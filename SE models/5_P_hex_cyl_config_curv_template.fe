/* Curtain under D–E down to F */
20   33    53    56   -55   -52

/* Small top-side triangles tying rims to the new “down” edges */

/* B_top: B_top – B→G – B→C */
21   60   -51   -4 color COLOR_P_B constraint 10 

/* C_top: C_top – C→B – C→G */
22   -6    49   -59 color COLOR_P_C  constraint 12

/* D_top: D_top – D→E – D→F */
23    32    52   -58 color COLOR_P_D constraint 14

/* E_top: E_top – E→F – E→D */
24    57   -53    34 color COLOR_P_E constraint 16 


/* ===== Additional rim-cap wedges to close the rims ===== */


read




set edge tension 0
set facet tension 0

