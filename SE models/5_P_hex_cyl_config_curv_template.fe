//returns whether a given edge id corresponds to an edge in the middle of a protein (i.e. not on its boundary)
function integer e_in_protein_middle(integer e_id) {
	if edges[e_id].__e_constraint_list[1] = 1 then {
		if edges[e_id].__e_constraint_list[2] >= FIRST_PROTEIN_CONSTRAINT then {
			return 1;
		};
	};
	return 0;
};


//returns whether a given edge id corresponds to a box edge
function integer e_on_edge(integer e_id) {
	if edges[e_id].__e_constraint_list[1] > 1 then {
		if edges[e_id].__e_constraint_list[2] < FIRST_PROTEIN_CONSTRAINT then {
			return 1;
		};
	};
	return 0;
}

//checks to see if any dihedral_angles are larger than they should be
//if they are the color of the appropriate faces is increased to reduce the edge lengths
procedure dihedral_color(real dihedral_cutoff) {
	local temp;
	local random1;
	local colorav;
	local ei; local fi;local ii;local vi;
	local countercol;

	foreach facet ff do {

		// if a dihedral angle is too large increase the color of surrounding faces
		if (ff.edges[1].dihedral > dihedral_cutoff or ff.edges[2].dihedral > dihedral_cutoff or ff.edges[3].dihedral > dihedral_cutoff) then {
			temp :=  ff.Ref_Lev;
			ff.Ref_Lev := temp + 1;
		};

		// if a dihedral angle is too small decease the color of surrounding faces
		// do not apply to faces on the edge of the box since dihedrals not calculated here
		if  (ff.edges[1].dihedral < dihedral_cutoff/DFACTOR  and ff.edges[2].dihedral < dihedral_cutoff/DFACTOR  and ff.edges[3].dihedral < dihedral_cutoff/DFACTOR
		and (e_on_edge(ff.edges[1].id) = 0) and (e_on_edge(ff.edges[2].id) = 0) and (e_on_edge(ff.edges[3].id) = 0)) then {
			if ff.Ref_Lev > 0 then {
				temp := ff.Ref_Lev;
				random1 := random;
				if random < COLOR_DOWN_CHANCE then {
					ff.Ref_Lev := temp - 1;
				};
			};
		};
	};

	//now set each facets color to average of its own and surrounding facets colors
	//this helps stability		
	foreach facet ff do {
		colorav := 0;
		countercol := 0;
		for (ei := 1; ei <= ff.valence; ei += 1) {
			for (fi := 1; fi <= ff.edges[ei].valence; fi += 1) {
				colorav += ff.edges[ei].facets[fi].Ref_Lev;
				countercol += 1;
			};
		};
		colorav := colorav/countercol;
		random1 := random;
		if random < (ceil(colorav) - colorav) then {
			colorav := floor(colorav);
		} else {
			colorav := ceil(colorav);
		};
		ff.Ref_Lev := colorav;
	};		
		
}

//unfixes all the vertices -- required before doing refinement, coarsening or retriangulation
procedure unfixall() {
	printf "unfixall() start...\n";
	unfix vertices where con >= 0;
	printf "unfixall() complete...\n";
}

//fixes vertices on protein constraints -- required before minimising energy -- assumes constraints are turned off
procedure fixall() {
	printf "fixall() start...\n";
	fix vertices where con >= FIRST_PROTEIN_CONSTRAINT;
	printf "fixall() complete...\n";
}

//turns protein constraints on -- required before doing refinement, coarsening or retriangulation
procedure conon() {
	printf "conon() start...\n";
	local ii;
	for (ii := 1; ii <= NUM_PROS; ii += 1) {	
		set vertex constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii where con=FIRST_PROTEIN_CONSTRAINT-2+2*ii or con=FIRST_PROTEIN_CONSTRAINT-1+2*ii;
		set vertex constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii where con=FIRST_PROTEIN_CONSTRAINT-1+2*ii;
	};
	printf "conon() complete...\n";
}

procedure conoff() {
	printf "conoff() start...\n";
	set vertex con 0;
	local ii; local cc;
	for (cc := 1; cc < FIRST_PROTEIN_CONSTRAINT; cc+=1) {
		set vertex con cc where on_constraint cc;
	};
	for (ii := 1; ii <= NUM_PROS; ii += 1) {
		set vertex con FIRST_PROTEIN_CONSTRAINT-2+2*ii where on_constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii;
		set vertex con FIRST_PROTEIN_CONSTRAINT-1+2*ii where on_constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii;
		unset vertex constraint FIRST_PROTEIN_CONSTRAINT-2+2*ii;
		unset vertex constraint FIRST_PROTEIN_CONSTRAINT-1+2*ii;
	};
	printf "conoff() complete...\n";
}

//deletes all edges smaller than they should be
procedure coarsen() {
	printf "coarsen() start...\n";
	unfixall();
	conon();
	delete edge ee where length < ee.lengoal;
	// there is a bug  in the line above (350)
	conoff();
	fixall();
	printf "coarsen() complete...\n";
}


//works out what length each edge should be
// works out what length each edge should be (now includes protein C2)
procedure setlengoals(){
  local colorlevel, fi;
  local xpos, ypos, zpos;
  local distance_first, distance_second, distance_third, distance_forth, distance_fifth;
  local distance_from_vertex, distance_from_vertex2, distance_from_vertex3, distance_from_vertex4;
  local nearest_radius;

  foreach edge ee do {
    xpos := (ee.vertex[1].x + ee.vertex[2].x)/2;
    ypos := (ee.vertex[1].y + ee.vertex[2].y)/2;
    zpos := (ee.vertex[1].z + ee.vertex[2].z)/2;

    // distances to the five protein centers
    distance_first  := sqrt((xpos-Ax )^2 + (ypos-Ay )^2 + (zpos-Az )^2); // A
    distance_second := sqrt((xpos-Bx )^2 + (ypos-By )^2 + (zpos-Bz )^2); // B
    distance_third  := sqrt((xpos-Cx )^2 + (ypos-Cy )^2 + (zpos-Cz )^2); // C
    distance_forth  := sqrt((xpos-Dx )^2 + (ypos-Dy )^2 + (zpos-Dz )^2); // D
    distance_fifth  := sqrt((xpos-Ex )^2 + (ypos-Ey )^2 + (zpos-Ez )^2); // E

    // nearest of the five
    distance_from_vertex  := minimum(distance_first,distance_second);
    distance_from_vertex2 := minimum(distance_from_vertex,distance_third);
    distance_from_vertex3 := minimum(distance_from_vertex2,distance_forth);
    distance_from_vertex4 := minimum(distance_from_vertex3,distance_fifth);

    // decide which radius to use for scaling
    if      distance_from_vertex4 == distance_first  then nearest_radius := RADIUS_SMALL_P1
    else if distance_from_vertex4 == distance_second then nearest_radius := RADIUS_SMALL_P2
    else if distance_from_vertex4 == distance_third  then nearest_radius := RADIUS_SMALL_P3
    else if distance_from_vertex4 == distance_forth  then nearest_radius := RADIUS_SMALL_P4
    else                                              nearest_radius := RADIUS_SMALL_P5;  // E

    // set lengoal and color (green if within its local small radius)
    if      distance_from_vertex4 == distance_first  and distance_first  < RADIUS_SMALL_P1 then {
      ee.lengoal := length_small;  set ee color green;
    }
    else if distance_from_vertex4 == distance_second and distance_second < RADIUS_SMALL_P2 then {
      ee.lengoal := length_small;  set ee color green;
    }
    else if distance_from_vertex4 == distance_third  and distance_third  < RADIUS_SMALL_P3 then {
      ee.lengoal := length_small;  set ee color green;
    }
    else if distance_from_vertex4 == distance_forth  and distance_forth  < RADIUS_SMALL_P4 then {
      ee.lengoal := length_small;  set ee color green;
    }
    else if distance_from_vertex4 == distance_fifth  and distance_fifth  < RADIUS_SMALL_P5 then {
      ee.lengoal := length_small;  set ee color green;
    }
  //  else if (ypos >= 0 or xpos >= 0) then {
   //   ee.lengoal := (distance_from_vertex4/nearest_radius)^LENGTH_SCALING * length_small;
   //   set ee color yellow;
   // }
    else {
      set ee color yellow;
      ee.lengoal := (distance_from_vertex4/nearest_radius)^LENGTH_SCALING * length_small;
      // print ee.id; print ee.lengoal; pause;   // keep for debugging if you like
    };

    // depth coloring / scaling by facet refinement level
    colorlevel := 0;
    for (fi := 1; fi <= ee.valence; fi += 1) {
      colorlevel += ee.facets[fi].Ref_Lev;
    };
    colorlevel := colorlevel/ee.valence;
    ee.lengoal := ee.lengoal / COLORSCALE^(colorlevel);
    // ee.lengoalset := 1;
  };
}



procedure color_edges_mid() {
	local distance;
	local colorlevel;
	local fi;
	local xpos; local ypos;
	foreach edge ee do {
		xpos := ee.vertex[1].x/2 + ee.vertex[2].x/2;
		ypos := ee.vertex[1].y/2 + ee.vertex[2].y/2;
		distance :=  (xpos^2+ypos^2)^0.5;
		if distance < RADIUS_SMALL_P1 then {
			ee.color := blue;
		} 
	};
}

procedure color_edges_p() {
	local distance;
	local colorlevel;
	local fi;
	local xpos; local ypos;
	foreach edge ee do {
		xpos := ee.vertex[1].x/2 + ee.vertex[2].x/2;
		ypos := ee.vertex[1].y/2 + ee.vertex[2].y/2;
		distance_first :=  ((xpos-Ax)^2+(ypos-Ay)^2)^0.5;
		distance_second :=  ((xpos-Bx)^2+(ypos-By)^2)^0.5;
		if distance_first < RADIUS_SMALL_P1 || distance_second < RADIUS_SMALL_P1 then {
			ee.color := blue;
		} 
	};
}

//refine all edges longer than they should be
procedure rnew() {
	printf "rnew() start...\n";
	unfixall();
	conon();
	setlengoals();
	foreach edges ee where ee.lengoal == 0 do {print ee.id};
	//pause;
	refine edge ee where length > RFACTOR * ee.lengoal; 
	conoff();
	fixall();
	printf "rnew() complete...\n";
}

//does equiangulation
procedure unew() {
	printf "unew() start...\n";
	unfixall();
	conon();
	u;
	conoff();
	fixall();
	printf "unew() complete...\n";
}

//refines, coarsens, etc surface
procedure rf() {
printf "rf() start...\n";
rnew();
unew();
coarsen();
unew();
printf "rf() complete...\n";}

//sets the level of refinement
//useful for initial setting up
procedure setlevel (integer level_set) {
	level := level_set;
	length_small := LENGTH_SMALL_L1*2/(2^level);
}

//converges the shape of the membrane 
procedure converge(integer hessian_calls, integer refine_every_step) {
	local energy_old; energy_old := total_energy;
	local energy_vold; energy_vold := total_energy;
	local energy_vvold; energy_vvold := total_energy;
	local energy_diff; energy_diff := 999999999;
	local repeat_counts; repeat_counts := 0;
	local trickystuff; 
	if hessian_calls = 0 then { trickystuff := 1; hessian_calls := 1 } else { trickystuff := 0 };
	while energy_diff > CONVERGE_TOLERANCE*maximum(maximum(energy_old,energy_vold),energy_vvold) do {
		if refine_every_step = 1 or (repeat_counts = 0 and !(trickystuff = 1 and hessian_calls > 1)) then { 
			rnew();unew();coarsen();unew();
		};
		{hessian_seek;} hessian_calls;
		energy_diff := minimum(minimum(abs(total_energy - energy_old),abs(total_energy-energy_vold)),abs(total_energy-energy_vvold));
		energy_vvold := energy_vold;
		energy_vold := energy_old;
		energy_old := total_energy;
		repeat_counts += 1;
		if trickystuff = 1 and repeat_counts = 4 then {
			repeat_counts := 0;
			hessian_calls += 1;
		};
	};
}

procedure converge_with_G(integer hessian_calls, integer refine_every_step) {
	local energy_old; energy_old := total_energy;
	local energy_vold; energy_vold := total_energy;
	local energy_vvold; energy_vvold := total_energy;
	local energy_diff; energy_diff := 999999999;
	local repeat_counts; repeat_counts := 0;
	local trickystuff; 
	if hessian_calls = 0 then { trickystuff := 1; hessian_calls := 1 } else { trickystuff := 0 };
	while energy_diff > CONVERGE_TOLERANCE*maximum(maximum(energy_old,energy_vold),energy_vvold) do {
		if refine_every_step = 1 or (repeat_counts = 0 and !(trickystuff = 1 and hessian_calls > 1)) then { 
			rnew();unew();coarsen();unew();
		};
		{g;} hessian_calls;
		energy_diff := minimum(minimum(abs(total_energy - energy_old),abs(total_energy-energy_vold)),abs(total_energy-energy_vvold));
		energy_vvold := energy_vold;
		energy_vold := energy_old;
		energy_old := total_energy;
		repeat_counts += 1;
		if trickystuff = 1 and repeat_counts = 4 then {
			repeat_counts := 0;
			hessian_calls += 1;
		};
	};
}

procedure fastconverge() {
	local energy_old; energy_old := total_energy; 
	local energy_vold; energy_vold := total_energy;	       
	local energy_vvold; energy_vvold := total_energy;
	local energy_diff; energy_diff := 999999999;
	loop_size := 2;
	counter := 0;
	while energy_diff > CONVERGE_TOLERANCE*maximum(maximum(energy_old,energy_vold),energy_vvold) do {
	        rnew();unew();coarsen();unew();
	        for (loop := 1; loop <= loop_size; loop += 1) {
		        hessian_seek;
			if loop = loop_size - 1 then {
			        energy_2ndtolast := total_energy;
			};
		};
		if loop_size > 1 and (abs(total_energy - energy_2ndtolast) < CONVERGE_TOLERANCE) then {
		   	loop_size -= 1;
			counter := 0;
		} else {
		        counter += 1;
		};
		if counter = 4 then {
		   	loop_size += 1;
			counter := 0;
		};
		energy_diff := minimum(minimum(abs(total_energy - energy_old),abs(total_energy-energy_vold)),abs(total_energy-energy_vvold));
		energy_vvold := energy_vold;
		energy_vold := energy_old;
		energy_old := total_energy;
	};
};

//adjusts the color of faces until there remain no edges with large dihedral angles
procedure colorconverge(integer hessian_calls) {
	local sharpangles;
	sharpangles := 1;
	local counter;
	counter := 0;
	while sharpangles != 0 do {
		if counter >= 2 AND Average_curvature_P_top <= 0.001 AND Average_curvature_P_rest <= 0.001 then {
			U;
			converge_with_G(10,1);
			U;
		}
		else {
			fastconverge();
		};
		dihedral_color(DIHEDRAL_MAX);
		sharpangles := 0;
		foreach edge ee where e_in_protein_middle(ee.id) = 0 and  dihedral > DIHEDRAL_MAX * DIHEDRAL_TOLERANCE_FACTOR do sharpangles += 1;
		printf "There are %d sharp edges left in the simulation\n",sharpangles;
		counter += 1;
	};
	
};

//runs converge and colorconverge
procedure convergesimple() {
	colorconverge(0);
	fastconverge();
};


procedure color_protein() {
	
	foreach facet ff where ff.color == red do {
		foreach ff.edges ee do ee.color := red;
	};
	
	foreach facet ff where ff.color == blue do {
		foreach ff.edges ee do ee.color := blue;
	};
}

procedure sphere_diagnostic()
{
  define vertex attribute dist_dev real;
  define vertex attribute dist_sq_dev real;
  define vertex attribute matches_sphere integer;
  define edge   attribute bad_edge integer;

  local ver_TOLERANCE;           // distance tolerance for “on the sphere”
  ver_TOLERANCE := 0.001;        // tweak if you like

  /* ── 1.  compute per‑vertex deviation from the big sphere ─────────── */
  foreach vertex vv do
  {
    // distance to shifted centre  (0,0,‑BIG_SPHERE_RADIUS)
    local distVV;
    distVV := sqrt( vv.x^2 + vv.y^2 + (vv.z + BIG_SPHERE_RADIUS)^2 );

    vv.dist_dev     := distVV - BIG_SPHERE_RADIUS;
    vv.dist_sq_dev  := vv.dist_dev^2;
    vv.matches_sphere := (abs(vv.dist_dev) <= ver_TOLERANCE ? 1 : 0);
  };

  /* ── 2.  global statistics ────────────────────────────────────────── */
  dev_sum := 0;
  sq_dev_sum := 0;
  max_dev := -1e20;
  min_dev :=  1e20;
  matching_vertices := 0;

  foreach vertex vv do
  {
    dev_sum  += vv.dist_dev;
    sq_dev_sum += vv.dist_sq_dev;
    if vv.dist_dev > max_dev then max_dev := vv.dist_dev;
    if vv.dist_dev < min_dev then min_dev := vv.dist_dev;
    if vv.matches_sphere == 1 then matching_vertices += 1;
  };

  printf "Vertex distance deviation wrt centre (0,0,%g):  min %g, max %g, avg %g, RMS %g\n",
         -BIG_SPHERE_RADIUS,
         min_dev, max_dev,
         dev_sum/vertex_count,
         sqrt(sq_dev_sum/vertex_count);

  percent_matching := 100.0 * matching_vertices / vertex_count;
  printf "Vertices within %.4g of sphere: %.2f %% (%d / %d)\n",
         ver_TOLERANCE, percent_matching,
         matching_vertices, vertex_count;

  /* ── 3.  colour edges that touch any off‑sphere vertex ─────────────── */
  bad_edge_count := 0;
  foreach edge ee do
  {
    if (ee.vertex[1].matches_sphere == 0) || (ee.vertex[2].matches_sphere == 0) then
    {
      ee.color := black;
      ee.bad_edge := 1;
      bad_edge_count += 1;
    } else {
      ee.bad_edge := 0;
    };
  };
  printf "Bad edges (touching off‑sphere vertices): %d / %d\n",
         bad_edge_count, edge_count;

  /* ── 4.  extra info  ──────────────────────────────────────────────── */
  printf "Protein curvature  (Average_curvature_P_general): %g\n", Average_curvature_P_general;
  printf "Protein cap radius (Rcap_P1):                    %g\n", Rcap_P1;
  printf "Membrane curvature (AVG_CURVATURE):              %g\n", AVG_CURVATURE;
  printf "Big sphere radius (BIG_SPHERE_RADIUS):           %g\n", BIG_SPHERE_RADIUS;
  printf "Total squared mean curvature (total_energy):     %g\n", total_energy;
};


function real calculate_vertex_A_angle(real Ax, real Ay, real Az, real Bx, real By, real Bz, real Cx, real Cy, real Cz)
{
  local ABx;
  local ABy;
  local ABz;
  local ACx;
  local ACy;
  local ACz;
  local dot_product_angle;
  local magnitude_AB;
  local magnitude_AC;
  local cos_angle;
  local angle_radians;
  local angle_degrees;

  ABx := Bx - Ax;
  ABy := By - Ay;
  ABz := Bz - Az;
  ACx := Cx - Ax;
  ACy := Cy - Ay;
  ACz := Cz - Az;

  dot_product_angle := ABx * ACx + ABy * ACy + ABz * ACz;

  magnitude_AB := sqrt(ABx^2 + ABy^2 + ABz^2);
  magnitude_AC := sqrt(ACx^2 + ACy^2 + ACz^2);

  cos_angle := dot_product_angle / (magnitude_AB * magnitude_AC);

  angle_radians := acos(cos_angle);
  angle_degrees := angle_radians * 180 / pi;

  return angle_degrees;
};

// Shortest-path distance along the lateral surface of the cylinder
// Uses unrolled-cylinder metric: sqrt( (Δx)^2 + (R * wrap(Δθ))^2 )
function real calculate_cylindrical_geodesic_distance(
    real point1_x, real point1_y, real point1_z,
    real point2_x, real point2_y, real point2_z)
{
  local angle_point1; local angle_point2;
  local raw_angle_difference; local wrapped_angle_difference;
  local axial_difference; local circumferential_distance;
  local total_geodesic_distance;

  // Angular positions on the cylinder (consistent with y = -R*sinθ, z = -R + R*cosθ)
  angle_point1 := atan2( -point1_y, point1_z + cylinder_R );
  angle_point2 := atan2( -point2_y, point2_z + cylinder_R );

  // Angle difference wrapped to (-pi, pi]
  raw_angle_difference := angle_point2 - angle_point1;
  wrapped_angle_difference := raw_angle_difference;
  while wrapped_angle_difference >  pi do
    wrapped_angle_difference := wrapped_angle_difference - 2*pi;
  while wrapped_angle_difference <= -pi do
    wrapped_angle_difference := wrapped_angle_difference + 2*pi;

  // Axial and circumferential components on the unrolled sheet
  axial_difference := point2_x - point1_x;
  circumferential_distance := cylinder_R * wrapped_angle_difference;

  // Geodesic distance on the cylinder
  total_geodesic_distance := sqrt( axial_difference^2 + circumferential_distance^2 );

  // Return non-negative distance
  return abs(total_geodesic_distance);
}




// Function to calculate the area of a sector of a circle analyticly
function real sector_area(real radius, real angle_deg) {
    local angle_rad; local sector_area;

    // Convert angle from degrees to radians
    angle_rad := angle_deg * pi / 180;
	
	sector_area := 0.5 * radius^2 * angle_rad;
    return sector_area;
}


// Area of cylinder patch bounded by E → B → G → F (axis = x; z-center = -cylinder_R)
function real calculate_cylindrical_patch_area_EBGF()
{
  // --- 1) raw angular positions (θ) from y = -R*sinθ, z = -R + R*cosθ ---
  local thetaE_raw; local thetaB_raw; local thetaG_raw; local thetaF_raw;
  thetaE_raw := atan2( -Ey, Ez + cylinder_R );
  thetaB_raw := atan2( -By, Bz + cylinder_R );
  thetaG_raw := atan2( -Gy, Gz + cylinder_R );
  thetaF_raw := atan2( -Fy, Fz + cylinder_R );

  // --- 2) unwrap to keep continuity along boundary order E→B→G→F ---
  local thetaE; local thetaB; local thetaG; local thetaF;
  local angle_delta;

  thetaE := thetaE_raw;

  angle_delta := thetaB_raw - thetaE;
  while angle_delta >  pi do angle_delta := angle_delta - 2*pi;
  while angle_delta <= -pi do angle_delta := angle_delta + 2*pi;
  thetaB := thetaE + angle_delta;

  angle_delta := thetaG_raw - thetaB;
  while angle_delta >  pi do angle_delta := angle_delta - 2*pi;
  while angle_delta <= -pi do angle_delta := angle_delta + 2*pi;
  thetaG := thetaB + angle_delta;

  angle_delta := thetaF_raw - thetaG;
  while angle_delta >  pi do angle_delta := angle_delta - 2*pi;
  while angle_delta <= -pi do angle_delta := angle_delta + 2*pi;
  thetaF := thetaG + angle_delta;

  // --- 3) isometric unroll: u = x (axial), v = R * θ (circumferential) ---
  local uE; local vE; local uB; local vB; local uG; local vG; local uF; local vF;
  uE := Ex;  vE := cylinder_R * thetaE;
  uB := Bx;  vB := cylinder_R * thetaB;
  uG := Gx;  vG := cylinder_R * thetaG;
  uF := Fx;  vF := cylinder_R * thetaF;

  // --- 4) polygon area on unrolled sheet (shoelace over E,B,G,F) ---
  local signed_double_area; local area_value;
  signed_double_area :=
      (uE*vB - uB*vE)
    + (uB*vG - uG*vB)
    + (uG*vF - uF*vG)
    + (uF*vE - uE*vF);

  area_value := 0.5 * abs(signed_double_area);
  return area_value;

  // Note: For the ideal rectangle geometry in your setup,
  // area ≈ |Ex - Bx| * cylinder_R * |thetaG - thetaE|.
}



procedure Min_Dist_refinment() {
	distance_AB := calculate_cylindrical_geodesic_distance(Ax, Ay, Az, Bx, By, Bz);
	distance_BC := calculate_cylindrical_geodesic_distance(Bx, By, Bz, Cx, Cy, Cz);
	
	if ((distance_AB <= MIN_DIST) || (distance_BC <= MIN_DIST)) then {
		//printf "Min Dist is: %f\n", MIN_DIST;
		//printf "distance_AB is: %f\n", distance_AB;
		//printf "distance_BC is: %f\n", distance_BC;
		LENGTH_SMALL_L1 := 0.5;
		//printf "LENGTH_SMALL_L1 is: %f\n", LENGTH_SMALL_L1;
		//pause;
	};
	
}

procedure initialise() {
	printf "initialise() start...\n";
	foreach face ff do ff.Ref_Lev := 0;
	foreach edge ee do ee.lengoalset := 0;
	//set facet tension 0;
	set farea modulus 0;
	Je.modulus := 1;
	//apply_average_curvature();
	conoff();
	fixall();
	//Min_Dist_refinment();

	setlevel(1);
	printf "initialise() complete...\n";
}



// calculates the area of the protein sector according to facet color at coltact angle ~0
procedure protein_segment_area() {
local plain_segment_P1; local plain_segment_P2;
foreach facet ff where ff.color == red do {plain_segment_P1 := plain_segment_P1 + ff.area}; 
printf "the plain segement area of protein 1 is: %f\n", plain_segment_P1;  
foreach facet ff where ff.color == blue do {plain_segment_P2 := plain_segment_P2 + ff.area}; 
printf "the plain segement area of protein 2 is: %f\n", plain_segment_P2/2;  
};


// Function to calculate the area of the sphere and the number of proteins on its surface
procedure OUTPUT_FUNCTION() {
    // Define all variables at the beginning of the function
    local big_sphere_area;
    local triangle_area; 
    local num_triangles;
	local protein_density;
    local protein_base_area_A;
    local protein_base_area_B;
    local protein_base_area_C;
	local protein_base_area_D;
	local protein_base_area_E;
    local total_protein_base_area;
    local num_proteins;
    local angle_A_value;
    local angle_B_value;
    local angle_C_value;
	local angle_D_value;
	local angle_E_value;
	local caps_area;
	local plane_bending_energy;
	local cap_bending_energy;
	local protein_caps_area;
	local cap_area_energy;
	local total_Bending_energy_calculated;
	
	
	arc_length_P1 := 0;
	P1_radius := 0;
	P1_area_segment := 0;
	arc_length_P2 := 0;
	P2_radius := 0;
	P2_area_segment := 0;
	arc_length_P3 := 0;
	P3_radius := 0;
	P3_area_segment := 0;
	P_segments_area_total := 0;
	plane_bending_energy := 0;
	cap_bending_energy := 0;
	protein_caps_area := 0;
	cap_area_energy := 0;
	proteins_base_sectors := 0;
	total_Bending_energy_calculated := 0;
	P_in_model := 360 / spin_angle_deg;
	
	
	foreach vertex vv where (con == 8 || con == 9 || con == 10 || con == 11 || con == 12 || con == 13 || con == 14 || con == 15 || con == 16 || con == 17) do {cap_bending_energy:=cap_bending_energy+vv.Je;}; // bending energy of the proteins edges
	foreach vertex vv where not (con == 8 || con == 9 || con == 10 || con == 11 || con == 12 || con == 13 || con == 14 || con == 15 || con == 16 || con == 17) do {plane_bending_energy:=plane_bending_energy+vv.Je;}; // bending energy of the membrane
	//foreach vertex vv where (con == 8 || con == 10 || con == 12 || con == 14 || con == 16) AND not (con == 9 || con == 11 || con == 13 || con == 15 || con == 17) do {cap_bending_energy:=cap_bending_energy+vv.Je;}; // bending energy of the proteins
	
	foreach facets ff where (ff.color == red || ff.color == blue) do {protein_caps_area := protein_caps_area+ff.area;}; // area of protein sphere caps
	
	membrane_area := total_area - protein_caps_area;

	total_Bending_energy := Je.value;
	total_Bending_energy_calculated := plane_bending_energy + cap_bending_energy;
	
	// Calculate the angles of the triangle in degrees
	
	angle_A_value := calculate_vertex_A_angle(Ax, Ay, Az, A_Bx, A_By, A_Bz, A_Ex, A_Ey, A_Ez);
	angle_B_value := calculate_vertex_A_angle(Bx, By, Bz, B_Ax, B_Ay, B_Az, B_Gx, B_Gy, B_Gz);
	angle_C_value := calculate_vertex_A_angle(Cx, Cy, Cz, C_Gx, C_Gy, C_Gz, C_Dx, C_Dy, C_Dz);
	angle_D_value := calculate_vertex_A_angle(Dx, Dy, Dz, D_Cx, D_Cy, D_Cz, D_Fx, D_Fy, D_Fz);
	angle_E_value := calculate_vertex_A_angle(Ex, Ey, Ez, E_Fx, E_Fy, E_Fz, E_Ax, E_Ay, E_Az);
	
	arc_AB := calculate_cylindrical_geodesic_distance(Ax, Ay, Az, Bx, By, Bz);
	arc_AC := calculate_cylindrical_geodesic_distance(Ax, Ay, Az, Cx, Cy, Cz);
	arc_AD := calculate_cylindrical_geodesic_distance(Ax, Ay, Az, Dx, Dy, Dz);
	arc_AE := calculate_cylindrical_geodesic_distance(Ax, Ay, Az, Ex, Ey, Ez);
    arc_BC := calculate_cylindrical_geodesic_distance(Bx, By, Bz, Cx, Cy, Cz);
	arc_CD := calculate_cylindrical_geodesic_distance(Cx, Cy, Cz, Dx, Dy, Dz);
	arc_DE := calculate_cylindrical_geodesic_distance(Dx, Dy, Dz, Ex, Ey, Ez);

	// Calculate the slice of the protein base for each vertex using the sector_area function
    protein_base_area_A := sector_area(rad_P1, angle_A_value);
    protein_base_area_B := sector_area(rad_P2, angle_B_value);
    protein_base_area_C := sector_area(rad_P3, angle_C_value);
	protein_base_area_D := sector_area(rad_P4, angle_D_value);
	protein_base_area_E := sector_area(rad_P5, angle_E_value);

    // Total protein base area in the triangle
    total_protein_base_area := protein_base_area_A + protein_base_area_B + protein_base_area_C + protein_base_area_D + protein_base_area_E;
	
    // Calculate the area of the big sphere analyticly
    big_sphere_area := 4 * pi * BIG_SPHERE_RADIUS^2;

    // Calculate the area of the half hexagon area
    half_hexagon_area := calculate_cylindrical_patch_area_EBGF();

    // Calculate the number of triangles needed to cover the whole sphere
    num_triangles := big_sphere_area / half_hexagon_area;
	
	// Calculate the area of the calculated big sphere
	big_sphere_calc_area := num_triangles * (total_area - caps_area + total_protein_base_area);

    // Calculate the total number of proteins
    num_proteins := (total_protein_base_area / (pi * rad_P1^2)) * num_triangles;
	
	protein_density := num_proteins / big_sphere_area;
	
	area_per_protein_anltc := big_sphere_area / num_proteins;
	
	area_per_protein_real := big_sphere_calc_area / num_proteins;
	
	num_triangles := 0; // overwrite only for the TXT output file

	num_proteins := 0;
	
	big_sphere_calc_area:= 0;
	
	if (NUMBER_OF_PROTEINS == 0) then {
	PSI := total_protein_base_area / total_protein_base_area;
	}

	else if (NUMBER_OF_PROTEINS == 106) then {
	PSI := protein_base_area_A / total_protein_base_area;
	}
	
	else if (NUMBER_OF_PROTEINS == 10) then {
	PSI := (protein_base_area_B) / total_protein_base_area;
	}

	else if (NUMBER_OF_PROTEINS == 204) then {
	PSI := (protein_base_area_B + protein_base_area_E) / total_protein_base_area;
	}

	else if (NUMBER_OF_PROTEINS == 42) then {
	PSI := (protein_base_area_C + protein_base_area_D) / total_protein_base_area;
	};
	
	PHI := total_protein_base_area / (total_area - caps_area + total_protein_base_area);

    // Output the results
	printf "OUTPUTLINE radius_P1 = %f\n", rad_P1;   // Replace with how you calculate radius if necessary
	printf "OUTPUTLINE radius_P2 = %f\n", rad_P2;   // Replace with how you calculate radius if necessary
	printf "OUTPUTLINE radius_P3 = %f\n", rad_P3;   // Replace with how you calculate radius if necessary
	printf "OUTPUTLINE radius_P4 = %f\n", rad_P4;   // Replace with how you calculate radius if necessary
	printf "OUTPUTLINE radius_P5 = %f\n", rad_P5;   // Replace with how you calculate radius if necessary
	
	printf "OUTPUTLINE Curv_P1_fam = %f\n", Curv_P1_fam;   // curvature of protein 1 family
	printf "OUTPUTLINE Curv_P2_fam = %f\n", Curv_P2_fam;   // curvature of protein 2 family
	
	printf "OUTPUTLINE Curv_P1 = %f\n", Average_curvature_P1;   // curvature of protein 1
	printf "OUTPUTLINE Curv_P2 = %f\n", Average_curvature_P2;   // curvature of protein 2
	printf "OUTPUTLINE Curv_P3 = %f\n", Average_curvature_P3;   // curvature of protein 3	
	printf "OUTPUTLINE Curv_P4 = %f\n", Average_curvature_P4;   // curvature of protein 4	
	printf "OUTPUTLINE Curv_P5 = %f\n", Average_curvature_P5;   // curvature of protein 5
	
	printf "OUTPUTLINE Avg_curv = %.10f\n", AVG_CURVATURE;   // curvature of big sphere	
	
    printf "OUTPUTLINE distance = %f\n", dist;  // distance between proteins 2 3 and 1
	
    printf "OUTPUTLINE membrane_tension = %f\n", MEMBRANE_TENSION;  // membrane tension
	
	printf "OUTPUTLINE total_energy = %f\n", total_energy * (10^10);  // total energy of the surface
    printf "OUTPUTLINE total_Bending_energy = %f\n", total_Bending_energy * (10^10);  // total bending energy
	printf "OUTPUTLINE total_Bending_energy_calculated = %f\n", total_Bending_energy_calculated * (10^10);  // total bending energy
	printf "OUTPUTLINE plane_bending_energy = %f\n", plane_bending_energy  * (10^10);  // proteins bending energy
	printf "OUTPUTLINE cap_bending_energy = %f\n", cap_bending_energy  * (10^10);  // proteins bending energy
	
    printf "OUTPUTLINE total_area = %f\n", total_area * (10^10);  // Output total area of the surface
	printf "OUTPUTLINE protein_caps_area = %f\n", protein_caps_area;  // proteins area
	printf "OUTPUTLINE membrane_area = %f\n", membrane_area;  // membrane area
    printf "OUTPUTLINE big_sphere_area = %f\n", big_sphere_area;  // Area of the sphere
	printf "OUTPUTLINE big_sphere_calc_area = %f\n", big_sphere_calc_area;  // Area of the sphere
    printf "OUTPUTLINE num_triangles = %f\n", num_triangles;  // Number of triangles
    printf "OUTPUTLINE protein_base_area_A = %f\n", protein_base_area_A;  // Area of protein base at A
    printf "OUTPUTLINE protein_base_area_B = %f\n", protein_base_area_B;  // Area of protein base at B
    printf "OUTPUTLINE protein_base_area_C = %f\n", protein_base_area_C;  // Area of protein base at C
	printf "OUTPUTLINE protein_base_area_D = %f\n", protein_base_area_D;  // Area of protein base at D
	printf "OUTPUTLINE protein_base_area_E = %f\n", protein_base_area_E;  // Area of protein base at C
	printf "OUTPUTLINE total_protein_base_area = %f\n", total_protein_base_area;  // proteins area
    printf "OUTPUTLINE num_proteins = %f\n", num_proteins;  // Number of proteins
	printf "OUTPUTLINE area_per_protein_anltc = %f\n", area_per_protein_anltc;  // Number of proteins
	printf "OUTPUTLINE area_per_protein_real = %f\n", area_per_protein_real;  // Number of proteins
	printf "OUTPUTLINE P_in_model = %d\n", NUMBER_OF_PROTEINS;  // Number of proteins
	printf "OUTPUTLINE arc_AB = %f\n", arc_AB;  // density of proteins
	printf "OUTPUTLINE arc_AC = %f\n", arc_AC;  // density of proteins
	printf "OUTPUTLINE arc_AD = %f\n", arc_AD;  // density of proteins
	printf "OUTPUTLINE arc_AE = %f\n", arc_AE;  // density of proteins
	printf "OUTPUTLINE arc_BC = %f\n", arc_BC;  // density of proteins
	printf "OUTPUTLINE arc_CD = %f\n", arc_CD;  // density of proteins
	printf "OUTPUTLINE arc_DE = %f\n", arc_DE;  // density of proteins
	printf "OUTPUTLINE analytic_total_area = %f\n", half_hexagon_area;
	printf "OUTPUTLINE PSI = %f\n", PSI;  // density of proteins
	printf "OUTPUTLINE PHI = %f\n", PHI;  // density of proteins
}


procedure extreme_case() {
	printf "extreme_case() start...\n";
	if (Dist >= 40) then {
	U;
	converge_with_G(10,1); 
	U;
	};
	printf "extreme_case() complete...\n";
}

// runme fast and furious
procedure runme() {
SUPPRESS_WARNING 1792;
true_DIHEDRAL_MAX := DIHEDRAL_MAX;
DIHEDRAL_MAX := 0.2;
//converge_Tol_simmilar_Jcap_case();
true_CONVERGE_TOLERANCE := CONVERGE_TOLERANCE;
CONVERGE_TOLERANCE := CONVERGE_TOLERANCE*1000;
//effective_area ON;
initialise();
setlevel(1);
{rf()} 8;
set facet tension 0.1;
converge(5,1); 
set facet tension 0;
set farea modulus MEMBRANE_TENSION; 
converge(5,1);
setlevel(2);
{rf()} 3;
converge(0,1);
setlevel(3);
{rf()} 3;
CONVERGE_TOLERANCE := true_CONVERGE_TOLERANCE;
convergesimple();
DIHEDRAL_MAX := true_DIHEDRAL_MAX;
convergesimple();
color_protein();
OUTPUT_FUNCTION();
};

