// Function to calculate the graphic string
procedure set_graphics(real spin_angle_deg) {

	local times;
    // Calculate times
    times := 360 / spin_angle_deg;
    if times == 4 then final_string := "((!b)|2(!b)|3(!b)|4(!b))";
    if times == 6 then final_string := "((!b)|2(!b)|3(!b)|4(!b)|5(!b)|6(!b))";
	if times == 8 then final_string := "((!b)|2(!b)|3(!b)|4(!b)|5(!b)|6(!b)|7(!b)|8(!b))";
	if times == 10 then final_string := "((!b)|2(!b)|3(!b)|4(!b)|5(!b)|6(!b)|7(!b)|8(!b)|9(!b)|10(!b))";
	if times == 12 then final_string := "((!b)|2(!b)|3(!b)|4(!b)|5(!b)|6(!b)|7(!b)|8(!b)|9(!b)|10(!b)|11(!b)|12(!b))";
    // Add more cases as needed up to a reasonable maximum
	
    // Display the resulting string
    printf "Constructed string: %s\n", final_string;
	GRAPHIC_STRING := final_string;
}

//if times == 3 then final_string := "((!b)|(!a!c)|(!a!b!c)|2(!b)|3(!b))";
//one_shape := "((!b)|2(!b)|3(!b)|4(!b)|5(!b)|6(!b))" /* to present 1 transformation of the whole shape */
//set_graphics(!b);
one_hexagon := "((!a!b)|2(!a!b))"
two_hexagon := "((!a!b)|2(!a!b))|!b!c((!a!b)|2(!a!b))"
transform_expr two_hexagon /* to present transformations */


